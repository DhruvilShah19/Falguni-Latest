rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Falguni Firestore Security Rules
//
// Philosophy: deny everything by default, whitelist only what is needed.
// Deploy with: firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // For Orders: the userId can be stored under three different field names
    // (web vs Flutter app variations). Ownership is satisfied if ANY matches.
    function isOrderOwner() {
      return isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userID == request.auth.uid ||
        resource.data.uid    == request.auth.uid
      );
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    match /Orders/{orderId} {

      // Anyone authenticated can read their own orders.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userID == request.auth.uid ||
        resource.data.uid    == request.auth.uid
      );

      // Creation: authenticated, all three userId fields must match the caller.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userID == request.auth.uid
        && request.resource.data.uid    == request.auth.uid
        // Must start as 'Pending Payment' — never skip straight to Received.
        && request.resource.data.status == 'Pending Payment';

      // Update: own order, only allowed fields, only the one legal transition.
      // Client can ONLY change status from 'Pending Payment' → 'Received'
      // and set paymentStatus/cashfreeDetails. Nothing else.
      allow update: if isOrderOwner()
        // Must have been in 'Pending Payment' state before the update.
        && resource.data.status == 'Pending Payment'
        // Only these fields may change. No rewrites of items, total, userId, etc.
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'paymentStatus', 'cashfreeDetails'])
        // The new status must be 'Received' — no other transitions from client.
        && request.resource.data.status == 'Received'
        // Total, items, and userId fields cannot be changed — ever.
        && request.resource.data.total    == resource.data.total
        && request.resource.data.userId   == resource.data.userId;

      // Delete: never from the client.
      allow delete: if false;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can only read/write their own document.
      allow read, write: if isOwner(userId);

      // Subcollections (Cart, DeliveryAddress, Recent Purchased Products, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Public catalogue — read-only for all, no writes from clients ────────
    match /Products/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /Categories/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /{flashCollection}/{docId} {
      // Allow Flash Sales Products and similar read-only catalogue collections.
      allow read: if flashCollection in ['Flash Sales Products', 'Banners', 'Notifications Settings', 'Push notification Settings', 'Delivery Fee'];
      allow write: if false;
    }

    match /Coupon/{docId} {
      // Coupons: authenticated users can read (to validate), not write.
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Deny everything else by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
